# --- Required ---
# LiveKit server (for voice room transport)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- STT Provider ---
# One of: vosk | sherpa | whisper_cpp | fixture
VOICE_STT_PROVIDER=fixture
VOSK_BASE_URL=http://127.0.0.1:2700
SHERPA_MODEL_DIR=
WHISPER_CPP_BASE_URL=

# --- TTS Provider ---
# One of: kokoro | fixture
VOICE_TTS_PROVIDER=fixture
KOKORO_BASE_URL=http://127.0.0.1:8880
VOICE_TTS_VOICE=af_heart

# --- Persistence ---
CALLCALLUM_DB_PATH=./data/callcallum.sqlite
CALLCALLUM_AUDIO_CACHE_DIR=./data/tts-cache
CALLCALLUM_RECORDINGS_DIR=./data/recordings

# --- OpenRouter (for non-MVP paths & intent matching) ---
OPENROUTER_API_KEY=

# --- OpenCode Go API (alternative LLM provider) ---
# AI_BASE_URL=https://opencode.ai/zen/go/v1
# AI_API_KEY=
